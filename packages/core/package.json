{
  "name": "@emgapps/orb-core",
  "version": "0.1.0",
  "description": "Framework-agnostic voice orb renderer, audio session, theme, and drag utilities.",
  "author": "Artem Hulmetov",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "homepage": "https://github.com/emgapps/orbio#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emgapps/orbio.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/emgapps/orbio/issues"
  },
  "keywords": [
    "voice",
    "orb",
    "webgl",
    "audio",
    "tts"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "pnpm build"
  }
}
