{
  "name": "@emgapps/orb-react",
  "version": "0.1.0",
  "description": "React component wrapper for Orbio voice-driven orb UI.",
  "author": "Artem Hulmetov",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "homepage": "https://github.com/emgapps/orbio#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emgapps/orbio.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/emgapps/orbio/issues"
  },
  "keywords": [
    "react",
    "voice",
    "orb",
    "webgl",
    "audio",
    "tts"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@emgapps/orb-core": "workspace:^"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
